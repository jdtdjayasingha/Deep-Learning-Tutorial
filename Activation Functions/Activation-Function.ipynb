    "Sigmoid Function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "901a2a5c-cb87-4c22-90f7-8aae31c8dbd7",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "f8671269-9e0c-45b6-976e-c00aee053e2b",
   "metadata": {},
   "outputs": [],
   "source": [
    "def sigmoid(x):\n",
    "    return 1.0 / (1.0 + np.exp(-x))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "48047fa4-dd82-43aa-8aea-7a087b80f871",
   "metadata": {},
   "outputs": [],
   "source": [
    "inputs = [13, 3, -12]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "716f05f6-61fe-465f-8c0c-e98e14abf856",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "13 --> 0.999997739675702\n",
      "3 --> 0.9525741268224334\n",
      "-12 --> 6.144174602214718e-06\n"
     ]
    }
   ],
   "source": [
    "for x in inputs:\n",
    "    print('{} --> {}'.format(x,sigmoid(x)))"
   ]
  }
